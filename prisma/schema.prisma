generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Church {
  id        String   @id @default(uuid())
  name      String
  address   String?
  phone     String?
  email     String?
  logo      String?
  timezone  String   @default("Asia/Kolkata")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  members  Member[]
  events   Event[]
  templates MessageTemplate[]
  sermons       Sermon[]
  announcements Announcement[]
  prayerRequests PrayerRequest[]
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("CHURCH_ADMIN") // SUPER_ADMIN, CHURCH_ADMIN
  churchId     String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  church          Church          @relation(fields: [churchId], references: [id])
  events          Event[]
  attendanceLog   Attendance[]
  auditLogs       AuditLog[]
}

model Member {
  id             String   @id @default(uuid())
  churchId       String
  fullName       String
  phone          String
  whatsappNumber String?
  email          String?
  ageGroup       String? // CHILD, YOUTH, ADULT, SENIOR
  gender         String? // MALE, FEMALE, OTHER
  area           String?
  avatar         String?
  address        String?
  bloodGroup     String?
  dateOfBirth    DateTime?
  familyMembers  String? // JSON string
  isSubscribed   Boolean  @default(true)
  isArchived     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  church            Church             @relation(fields: [churchId], references: [id])
  eventRecipients   EventRecipient[]
  communicationLogs CommunicationLog[]
  callLogs          CallLog[]
  rsvps             Rsvp[]
  qrCodes           QrCode[]
  followUps         FollowUp[]
  attendance        Attendance[]
  prayerRequests    PrayerRequest[]
  bibleReading      BibleReading[]
  notifications     UserNotification[]
  sermonBookmarks   SermonBookmark[]

  @@unique([churchId, phone])
}

model Event {
  id               String   @id @default(uuid())
  churchId         String
  createdBy        String
  name             String
  slug             String   @unique
  category         String
  description      String?
  startDate        DateTime
  endDate          DateTime?
  startTime        String
  venue            String
  locationLink     String?
  posterImage      String?
  organizerContact String?
  registrationReq  Boolean  @default(false)
  voiceEnabled     Boolean  @default(true)
  rsvpEnabled      Boolean  @default(true)
  qrAttendance     Boolean  @default(true)
  status           String   @default("DRAFT") // DRAFT, PUBLISHED, LIVE, CANCELLED, COMPLETED
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  church            Church             @relation(fields: [churchId], references: [id])
  creator           User               @relation(fields: [createdBy], references: [id])
  recipients        EventRecipient[]
  communicationLogs CommunicationLog[]
  callCampaigns     CallCampaign[]
  rsvps             Rsvp[]
  qrCodes           QrCode[]
  attendance        Attendance[]
  followUps         FollowUp[]
  notificationLogs  NotificationLog[]
}

model MessageTemplate {
  id        String   @id @default(uuid())
  churchId  String
  name      String
  subject   String?
  body      String
  variables String   @default("[]") // JSON array
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  church Church @relation(fields: [churchId], references: [id])
}

model EventRecipient {
  id        String   @id @default(uuid())
  eventId   String
  memberId  String
  status    String   @default("SELECTED") // SELECTED, INVITED, COMPLETED
  createdAt DateTime @default(now())

  event  Event  @relation(fields: [eventId], references: [id])
  member Member @relation(fields: [memberId], references: [id])

  @@unique([eventId, memberId])
}

model CommunicationLog {
  id             String   @id @default(uuid())
  eventId        String
  memberId       String
  channel        String   // PUSH, WHATSAPP, SMS, EMAIL, CALL
  status         String   // PREPARED, SENT, DELIVERED, OPENED, FAILED
  messageContent String?
  sentAt         DateTime?
  deliveredAt    DateTime?
  openedAt       DateTime?
  createdAt      DateTime @default(now())

  event  Event  @relation(fields: [eventId], references: [id])
  member Member @relation(fields: [memberId], references: [id])
}

model PushSubscription {
  id        String   @id @default(uuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  memberId  String?
  userAgent String?
  createdAt DateTime @default(now())
}

model NotificationLog {
  id             String   @id @default(uuid())
  title          String
  body           String
  eventId        String?
  sentBy         String
  totalSent      Int      @default(0)
  totalDelivered Int      @default(0)
  totalOpened    Int      @default(0)
  createdAt      DateTime @default(now())

  event Event? @relation(fields: [eventId], references: [id])
}

model CallCampaign {
  id             String    @id @default(uuid())
  eventId        String
  name           String
  status         String    @default("QUEUED") // QUEUED, RUNNING, PAUSED, COMPLETED, CANCELLED
  totalCalls     Int       @default(0)
  answered       Int       @default(0)
  noAnswer       Int       @default(0)
  busy           Int       @default(0)
  failed         Int       @default(0)
  maxRetries     Int       @default(2)
  retryDelayMin  Int       @default(30)
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())

  event    Event     @relation(fields: [eventId], references: [id])
  callLogs CallLog[]
}

model CallLog {
  id            String    @id @default(uuid())
  campaignId    String
  memberId      String
  phone         String
  status        String    @default("QUEUED") // QUEUED, INITIATED, RINGING, ANSWERED, COMPLETED, NO_ANSWER, BUSY, FAILED, CANCELLED
  attempts      Int       @default(0)
  lastAttemptAt DateTime?
  callDuration  Int?
  recordingUrl  String?
  retryCount    Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  campaign CallCampaign @relation(fields: [campaignId], references: [id])
  member   Member       @relation(fields: [memberId], references: [id])
}

model Rsvp {
  id            String   @id @default(uuid())
  eventId       String
  memberId      String?
  guestName     String?
  response      String   // ATTENDING, MAYBE, NOT_ATTENDING
  guestCount    Int      @default(0)
  prayerRequest String?
  message       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  event  Event  @relation(fields: [eventId], references: [id])
  member Member? @relation(fields: [memberId], references: [id])
  qrCode QrCode[]

  @@unique([eventId, memberId])
}

model QrCode {
  id          String    @id @default(uuid())
  eventId     String
  memberId    String?
  rsvpId      String? @unique
  token       String    @unique
  isCheckedIn Boolean   @default(false)
  checkedInAt DateTime?
  createdAt   DateTime  @default(now())

  event  Event  @relation(fields: [eventId], references: [id])
  member Member? @relation(fields: [memberId], references: [id])
  rsvp   Rsvp?   @relation(fields: [rsvpId], references: [id])
}

model Attendance {
  id          String   @id @default(uuid())
  eventId     String
  memberId    String?
  qrCodeId    String?
  checkedInAt DateTime @default(now())
  checkedInBy String?
  method      String   // QR_SCAN, MANUAL

  event  Event  @relation(fields: [eventId], references: [id])
  member Member? @relation(fields: [memberId], references: [id])
  user   User?  @relation(fields: [checkedInBy], references: [id])
}

model FollowUp {
  id          String   @id @default(uuid())
  eventId     String
  memberId    String
  reason      String   // NO_RSVP, UNANSWERED_CALL, NOT_OPENED, NOT_SUBSCRIBED
  status      String   @default("PENDING") // PENDING, CONTACTED, RESOLVED
  notes       String?
  contactedBy String?
  contactedAt DateTime?
  createdAt   DateTime @default(now())

  event  Event  @relation(fields: [eventId], references: [id])
  member Member @relation(fields: [memberId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Sermon {
  id          String   @id @default(uuid())
  churchId    String
  title       String
  speaker     String
  date        DateTime
  description String?
  videoUrl    String?
  audioUrl    String?
  notesPdf    String?
  thumbnail   String?
  duration    Int? // minutes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  church    Church           @relation(fields: [churchId], references: [id])
  bookmarks SermonBookmark[]
}

model SermonBookmark {
  id        String   @id @default(uuid())
  memberId  String
  sermonId  String
  createdAt DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id])
  sermon Sermon @relation(fields: [sermonId], references: [id])

  @@unique([memberId, sermonId])
}

model Announcement {
  id          String   @id @default(uuid())
  churchId    String
  title       String
  description String
  attachment  String?
  priority    String   @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  church Church @relation(fields: [churchId], references: [id])
}

model PrayerRequest {
  id          String   @id @default(uuid())
  memberId    String
  churchId    String
  title       String
  description String?
  isAnonymous Boolean  @default(false)
  status      String   @default("ACTIVE") // ACTIVE, ANSWERED, ARCHIVED
  prayerCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  member Member @relation(fields: [memberId], references: [id])
  church Church @relation(fields: [churchId], references: [id])
}

model BibleReading {
  id          String   @id @default(uuid())
  memberId    String
  date        DateTime
  book        String
  chapter     Int
  verses      String? // "1-10" or "1,3,5-8"
  notes       String?
  createdAt   DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id])

  @@unique([memberId, date])
}

model UserNotification {
  id        String   @id @default(uuid())
  memberId  String
  title     String
  body      String
  type      String   @default("GENERAL") // EVENT, PRAYER, ATTENDANCE, GENERAL
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id])
}
